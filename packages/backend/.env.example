# ── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=SaaS Collaboration Platform

# ── Database (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://saas_user:saas_password@localhost:5432/saas_db?schema=public

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── MinIO (S3-compatible storage) ────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=saas-uploads
MINIO_USE_SSL=false

# ── Swagger ──────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# ── LLM (DeepSeek / OpenAI-compatible) ────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=3
